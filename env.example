## Environment configuration for mam-audiofinder
#
# App-level settings are normally saved through /setup into /data/config.json.
# Host storage paths are mounted directly in docker-compose.yml:
#   - downloads must be visible inside this container at /downloads
#   - the Audiobookshelf library must be visible inside this container at /library

# --- app web UI port ---
APP_PORT=8008

# --- published image tag used by docker-compose.yml ---
IMAGE_TAG=latest

# --- app state ---
DATA_DIR=/path/to/appdata/mam-audiofinder/data

# --- container user/permissions ---
PUID=99
PGID=100
UMASK=0002

# --- optional: lock setup UI after configuration ---
# DISABLE_SETUP=1

# --- optional: alternate config path for development/advanced installs ---
# APP_CONFIG_PATH=/data/config.json

# --- optional app config fallbacks; usually use /setup instead ---
# MAM_COOKIE=mam_id=your_cookie_here
# TRANSMISSION_URL=http://transmission:9091/transmission/rpc
# TRANSMISSION_USER=youruser
# TRANSMISSION_PASS=yourpass
# TRANSMISSION_LABEL=mam-audiofinder
# AUTO_IMPORT_ENABLED=true
# AUTO_IMPORT_POLL_INTERVAL=30
